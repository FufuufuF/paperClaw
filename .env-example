# Copy this file to .env, then uncomment exactly one provider block.
#
# paperClaw currently supports DeepSeek directly and OpenAI-compatible
# /v1/chat/completions providers through PAPERCLAW_PROVIDER.
#
# Common optional runtime settings:
# PAPERCLAW_CLI_UI=plain
# PAPERCLAW_STORE_DIR=paperclaw-store
# PAPERCLAW_CONTEXT_WINDOW_TOKENS=24000
# PAPERCLAW_MAX_TOKENS=8192
# PAPERCLAW_TEMPERATURE=0.3

# ---------------------------------------------------------------------
# DeepSeek (default)
# ---------------------------------------------------------------------
# PAPERCLAW_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_API_BASE=https://api.deepseek.com
# PAPERCLAW_MODEL=deepseek-chat

# ---------------------------------------------------------------------
# OpenAI
# ---------------------------------------------------------------------
# PAPERCLAW_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE=https://api.openai.com
# PAPERCLAW_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------
# OpenRouter
# ---------------------------------------------------------------------
# PAPERCLAW_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_API_BASE=https://openrouter.ai/api
# PAPERCLAW_MODEL=openai/gpt-4o-mini

# ---------------------------------------------------------------------
# Moonshot / Kimi
# ---------------------------------------------------------------------
# PAPERCLAW_PROVIDER=moonshot
# MOONSHOT_API_KEY=sk-...
# MOONSHOT_API_BASE=https://api.moonshot.cn
# PAPERCLAW_MODEL=moonshot-v1-8k

# ---------------------------------------------------------------------
# Alibaba DashScope / Qwen OpenAI-compatible mode
# ---------------------------------------------------------------------
# PAPERCLAW_PROVIDER=dashscope
# DASHSCOPE_API_KEY=sk-...
# DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode
# PAPERCLAW_MODEL=qwen-plus

# ---------------------------------------------------------------------
# SiliconFlow
# ---------------------------------------------------------------------
# PAPERCLAW_PROVIDER=siliconflow
# SILICONFLOW_API_KEY=sk-...
# SILICONFLOW_API_BASE=https://api.siliconflow.cn
# PAPERCLAW_MODEL=Qwen/Qwen2.5-7B-Instruct

# ---------------------------------------------------------------------
# Generic OpenAI-compatible provider
# ---------------------------------------------------------------------
# PAPERCLAW_PROVIDER=openai-compatible
# PAPERCLAW_API_KEY=sk-...
# PAPERCLAW_API_BASE=https://example.com
# PAPERCLAW_MODEL=provider-model-name

# ---------------------------------------------------------------------
# Custom OpenAI-compatible provider
# ---------------------------------------------------------------------
# PAPERCLAW_PROVIDER=custom
# CUSTOM_API_KEY=sk-...
# CUSTOM_API_BASE=http://localhost:11434
# PAPERCLAW_MODEL=local-model-name
