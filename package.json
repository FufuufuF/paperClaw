{
  "name": "paperclaw",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "chat": "pnpm --filter @paperclaw/cli exec tsx src/main.ts",
    "test": "pnpm test:chat && pnpm test:search",
    "test:search": "pnpm --filter @paperclaw/search exec tsx src/__tests__/smoke.ts",
    "test:chat": "tsx tests/agent/smoke.test.ts"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.0.0"
}
